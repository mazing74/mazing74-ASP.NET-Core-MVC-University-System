@model IEnumerable<Student>
@{
    ViewData["Title"] = "Index";

}
<a asp-action="Create"  mb-2">Create New Student</a>
<h3> All Students</h3>
<table class="table table-hover">
    <thead>
        <tr>
            <th>Image</th>
            <th>Name</th>
            <th>SSN</th>
            <th>Address</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Department</th>
            <th colspan="3" style="text-align: center;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model)
        {
            <tr>
                <td><img src="~/images/@student.image" alt="@student.name"  class="img-fluid" style="max-width: 100px; ma" /></td>
                <td>@student.name</td>
                <td>@student.ssn</td>
                <td>@Html.DisplayFor(m => student.address)</td>
                <td>@Html.DisplayFor(m => student.email)</td>
                <td>@student.phone</td>
                <td>@student.Department?.Name</td>

                <td>
                    <a asp-action="Details" asp-route-id="@student.Id" class="btn  btn-sm">Details</a>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@student.Id" class="btn  btn-sm">Edit</a>
                </td>
                <td>
                    <a asp-action="Delete" asp-route-id="@student.Id" class="btn btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

