@model Student 
@{
    var departments = new SelectList(ViewBag.departments,"Id", "Name");
 }

<div class="form-group">
    <label class="col-form-label" asp-for="name"></label>
    <input class="form-control" asp-for="name" />
    <span asp-validation-for="name" class="text-danger"></span>
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="ssn"></label>
    <input class="form-control" asp-for="ssn" />
    <span asp-validation-for="ssn" class="text-danger"></span>
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="address"></label>
    <input class="form-control" asp-for="address" />
    <span asp-validation-for="address" class="text-danger"></span>
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="email"></label>
    <input type="email" class="form-control" asp-for="email" />
    <span asp-validation-for="email" class="text-danger"></span>
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="phone"></label>
    <input class="form-control" asp-for="phone" />
    <span asp-validation-for="phone" class="text-danger"></span>
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="image"></label>
    <input type="file" name="imageFile" accept="image/*" class="form-control" asp-for="image" />
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="Department"></label>
    <select class="form-control" asp-for="DepartmentId" asp-items="@departments">
        <option value="null">---------Select Department--------</option>
    </select>
</div>
