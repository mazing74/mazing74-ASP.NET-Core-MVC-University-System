@model Student
<div class="form-group">
    <label class="col-form-label" asp-for="name"></label>
    <input readonly class="form-control" asp-for="name" />
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="ssn"></label>
    <input readonly class="form-control" asp-for="ssn" />
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="address"></label>
    <input readonly class="form-control" asp-for="address" />
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="email"></label>
    <input readonly type="email" class="form-control" asp-for="email" />
</div>
<div class="form-group">
    <label class="col-form-label" asp-for="phone"></label>
    <input readonly class="form-control" asp-for="phone" />
</div>